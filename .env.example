# Server
PORT=5001
# Local (requiere MongoDB instalado y corriendo):
# MONGO_URI=mongodb://localhost:27017/montessori
# MongoDB Atlas (recomendado — gratis):
MONGO_URI=mongodb+srv://USUARIO:PASSWORD@cluster0.xxxxx.mongodb.net/montessori?retryWrites=true&w=majority
JWT_SECRET=change-this-to-a-long-random-secret
CORS_ORIGINS=http://localhost:5173,https://tu-app.vercel.app
FRONTEND_URL=http://localhost:5173

# Email (optional — logs to console if not set)
EMAIL_USER=
EMAIL_PASS=

# Admin seed (first run)
ADMIN_EMAIL=adriana@ejemplo.com
ADMIN_PASSWORD=Admin123!
ADMIN_NAME=Adriana Villalobos

# Stripe Phase 2 (optional)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_SINGLE=
STRIPE_PRICE_PACK4=

# Frontend (solo Vercel — ver client/.env.example)
# VITE_API_URL=https://tu-api.up.railway.app
